# Python build/cache
__pycache__/
*.pyc
*.pyo

# OS / editor junk
.DS_Store
Thumbs.db
*.tmp
*.swp
*~

# Reference clone — PianoBooster has its own upstream .git; tracked separately, not here
/pianobooster/

# Machine-local Claude settings (keep .claude/agents/, drop local overrides)
.claude/settings.local.json
.claude/projects/

# Personal Pi target for deploy.ps1 / setup-pi-key.ps1 (user@host) — never commit
.pitv-host

# Stray screenshots from debugging
/ui*.png
/kl.png
/kc.png
/pitv_*.png

# TLS keys/certs live ONLY on the Pi (~/webpiano/certs) — never commit private keys
webpiano/certs/
*.pem
*-key.pem

# WebAudioFont samples (~12 MB) live on the Pi; regenerate with pi/fetch-waf.sh
webpiano/web/waf/
